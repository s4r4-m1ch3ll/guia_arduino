void setup() {
  if(!oled.begin(SSD1306_SWITCHCAPVCC, 0x3C)) { 
    for(;;); 
  }
  
  oled.clearDisplay();
  oled.setTextColor(SSD1306_WHITE);
  oled.setTextSize(1);
  
  oled.setCursor(10, 0);
  oled.print("Centro de Diseno y");
  oled.setCursor(34, 10); 
  oled.print("Metrologia");
  
  oled.drawBitmap(36, 24, logoSena, 56, 56, SSD1306_WHITE);
  
  oled.display(); 
}

